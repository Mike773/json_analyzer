# Активный чат-провайдер: openai | gigachat
LLM_PROVIDER=gigachat

# Имя чат-модели активного провайдера
# (gigachat: напр. GigaChat-2-Max; openai: напр. gpt-4o)
LLM_MODEL=GigaChat-2-Max

# --- GigaChat: чат при LLM_PROVIDER=gigachat + ВСЕГДА эмбеддинги ---
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=0
GIGACHAT_EMBEDDINGS_MODEL=EmbeddingsGigaR
# Кастомный API-эндпоинт GigaChat-совместимого шлюза.
# Если задан и шлюз без авторизации — GIGACHAT_CREDENTIALS можно оставить пустым.
GIGACHAT_BASE_URL=

# --- OpenAI: чат при LLM_PROVIDER=openai ---
OPENAI_API_KEY=

# --- PostgreSQL (pgvector) ---
POSTGRES_DSN=postgresql://analyzer:analyzer@localhost:5432/analyzer
# Схема в PostgreSQL для кэша metric_embeddings.
# Пусто => search_path не трогается (используется дефолтный, обычно public).
# Если задана — схема автосоздаётся, search_path = <schema>, public, ext
# (public/ext добавлены: в разных БД pgvector стоит в разных схемах).
POSTGRES_SCHEMA=

# --- Аналитика ---
# Порог |z-score| для пометки строки метрики как аномалии
ANOMALY_ZSCORE_THRESHOLD=2.0

# Размерность вектора эмбеддингов (EmbeddingsGigaR = 2560).
# Можно не задавать: при старте размерность определяется автоматически,
# а кэш metric_embeddings пересоздаётся, если она изменилась.
EMBEDDING_DIM=2560

# Датасет по умолчанию
DEFAULT_DATASET=test_metrics.json
